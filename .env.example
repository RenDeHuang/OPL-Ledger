# OPL Ledger local/pre-launch environment template.
#
# Do not commit real passwords, tokens, kubeconfigs, cloud credentials, or
# production endpoint secrets. This repository is pre-launch only; OPL Cloud /
# medopl-3 remains the primary production path until cutover is explicitly
# approved.

# ---------------------------------------------------------------------------
# Implemented by the current Go API
# ---------------------------------------------------------------------------

# HTTP API port. Defaults to 8788 when unset.
PORT=8788

# PostgreSQL persistence. When empty, the API uses an in-memory store for local
# tests and development. For local pre-launch testing, use a local database.
#
# Example:
# DATABASE_URL=postgres://opl_ledger:opl_ledger_dev@127.0.0.1:5432/opl_ledger?sslmode=disable
DATABASE_URL=

# ---------------------------------------------------------------------------
# Required for one-person-lab-cloud billing parity before production cutover
# ---------------------------------------------------------------------------

# Keep these aligned with medopl-3 / OPL-Cloud.
OPL_BILLING_MARKUP=0.2
OPL_BASIC_COMPUTE_HOURLY_CNY=0.39
OPL_PRO_COMPUTE_HOURLY_CNY=3.09
OPL_STORAGE_GB_MONTH_CNY=0.36

# Reconciliation guard policy. The medopl-3 guard fails closed when the latest
# required reconciliation report is missing, stale, or failed.
OPL_RECONCILIATION_MAX_AGE_HOURS=30
OPL_RECONCILIATION_TOLERANCE_CNY=0.01

# ---------------------------------------------------------------------------
# Required before Console/Fabric integration
# ---------------------------------------------------------------------------

# Internal URL that OPL Console will call once shadow mode starts.
OPL_LEDGER_INTERNAL_URL=http://127.0.0.1:8788

# Service-to-service authentication. Leave empty only for local pre-integration
# development; set both values before any Console/Fabric integration.
OPL_LEDGER_SERVICE_TOKEN=
OPL_LEDGER_ADMIN_TOKEN=

# Keep cutover disabled until Ledger has wallet, hold, settlement, audit,
# evidence, and migration parity.
OPL_LEDGER_SHADOW_MODE=1
OPL_LEDGER_CUTOVER_ENABLED=0

# Optional source Console endpoint for shadow comparison tooling. Use local or
# approved staging endpoints only during pre-launch.
OPL_CLOUD_BASE_URL=http://127.0.0.1:8787

# ---------------------------------------------------------------------------
# Read-only Kubernetes evidence collection
# ---------------------------------------------------------------------------

# client-go should be used only for evidence reads in opl-ledger. It must not
# provision, mutate, delete, or apply Kubernetes resources.
KUBECONFIG=
OPL_K8S_NAMESPACE=opl-cloud
TENCENT_DEPLOY_CLUSTER_ID=
OPL_LEDGER_K8S_READ_ONLY=1
OPL_WORKSPACE_ID_LABEL=oplcloud.cn/workspace-id
